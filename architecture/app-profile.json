  "dataModel": {
    "schemaId": "firevault.account.v1",
    "enabledFieldIds": [
      "name",
      "externalAccountId",
      "sitePhone",
      "street",
      "city",
      "state",
      "zip",
      "gps",
      "panelManufacturer",
      "panelModel",
      "notes"
    ],
    "requiredFieldIds": [
